#!/bin/bash

export REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export CONTAINER_NAME="rfit"
export IMAGE_NAME="rfit"
SERVICE_NAME="rfit"

SCRIPT_NAME="rfit"
SCRIPT_PATH="/usr/local/bin/$SCRIPT_NAME"

######################################################

function nuke() {
    docker container prune -f
    docker images --filter "dangling=true" -q | xargs -r docker rmi
    docker volume prune -f
    docker builder prune -a -f
}

function copy_to_bin() {
    echo "💾 Copying script from $REPO to $SCRIPT_PATH..."
    sudo cp "$REPO/$SCRIPT_NAME" "$SCRIPT_PATH"
    sudo chmod +x "$SCRIPT_PATH"
    echo "✅ System script updated."
    exit 0
}

######################################################

function redeploy() {
    build
    up
}

function up() {
    docker compose -f "$REPO/docker-compose.yml" up -d ${SERVICE_NAME}
}

function down() {
    docker compose -f "$REPO/docker-compose.yml" down
}

function shell() {
    docker compose -f "$REPO/docker-compose.yml" exec ${SERVICE_NAME} bash
}

function purge() {
    docker compose -f "$REPO/docker-compose.yml" down --rmi all --volumes --remove-orphans
}

function build() {
    purge
    docker compose -f "$REPO/docker-compose.yml" build --no-cache ${SERVICE_NAME}
    nuke
}

function logs() {
    docker compose -f "$REPO/docker-compose.yml" logs -f ${SERVICE_NAME}
}

function env_var() {
    docker inspect ${CONTAINER_NAME} 2>/dev/null | jq '.[0].Config.Env'
}

function pass_to_claude() {
    docker compose -f "$REPO/docker-compose.yml" exec ${SERVICE_NAME} claude "$@"
}

######################################################

case "$1" in
    nuke)       nuke ;;
    redeploy)   redeploy ;;
    copy)       copy_to_bin ;;
    up)         up ;;
    down)       down ;;
    shell)      shell ;;
    purge)      purge ;;
    build)      build ;;
    logs)       logs ;;
    env_var)    env_var ;;
    *)
    echo "unknown command" ;;
esac